# Super Dev Deployment Environment Template
# Platform: all
# only_missing: true

# Docker 镜像仓库用户名
DOCKER_USERNAME="<value>"

# Docker 镜像仓库密码/Token
DOCKER_PASSWORD="<value>"

# 开发环境 Kubernetes kubeconfig
KUBE_CONFIG_DEV="<value>"

# 生产环境 Kubernetes kubeconfig
KUBE_CONFIG_PROD="<value>"

# GitLab Registry 用户名
CI_REGISTRY_USER="<value>"

# GitLab Registry 密码/Token
CI_REGISTRY_PASSWORD="<value>"

# 开发环境 K8s 上下文
KUBE_CONTEXT_DEV="<value>"

# 生产环境 K8s 上下文
KUBE_CONTEXT_PROD="<value>"

# Azure ACR 服务连接标识
AZURE_ACR_SERVICE_CONNECTION="<value>"

# 开发环境 AKS 服务连接标识
AZURE_DEV_K8S_CONNECTION="<value>"

# 生产环境 AKS 服务连接标识
AZURE_PROD_K8S_CONNECTION="<value>"

# 镜像仓库地址
REGISTRY_URL="<value>"
