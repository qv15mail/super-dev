{
  "name": "@super-dev/openclaw-plugin",
  "version": "2.3.8",
  "description": "Super Dev pipeline governance plugin for OpenClaw - research-first, commercial-grade AI coding delivery",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "README.md",
    "src",
    "dist",
    "skills/super-dev",
    "skills/super-dev-seeai",
    "openclaw.plugin.json"
  ],
  "openclaw": {
    "extensions": [
      "./src/index.ts"
    ]
  },
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "dev": "tsc --watch",
    "prepublishOnly": "tsc",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "openclaw",
    "openclaw-plugin",
    "super-dev",
    "ai-development",
    "pipeline",
    "code-quality",
    "governance"
  ],
  "author": "Excellent <11964948@qq.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/shangyankeji/super-dev",
    "directory": "super-dev-openclaw"
  },
  "dependencies": {
    "@sinclair/typebox": "^0.32.0"
  },
  "devDependencies": {
    "openclaw": ">=2026.1.0",
    "typescript": "^5.5.0"
  },
  "peerDependencies": {
    "openclaw": ">=2026.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
